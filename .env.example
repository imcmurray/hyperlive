# Copy to .env and fill in. .env is gitignored — never commit your stream key.

# --- YouTube Live RTMP ---------------------------------------------------
# Get these from YouTube Studio → Create → Go live → Stream settings.
# "Stream URL" is usually rtmp://a.rtmp.youtube.com/live2
# "Stream key" is the secret — paste it here.
YT_RTMP_URL=rtmp://a.rtmp.youtube.com/live2
YT_STREAM_KEY=

# --- Encode / output -----------------------------------------------------
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FPS=30
VIDEO_BITRATE=4500k
AUDIO_MODE=silent          # silent | tone

# --- Local control plane -------------------------------------------------
CONTROL_PORT=8080
DIRECTIVES_FILE=/app/control/directives.json

# --- Dev convenience -----------------------------------------------------
# DRY_RUN=true renders the scene + control server WITHOUT pushing to YouTube.
# Use it to develop the scene with no stream key. Set false to actually stream.
DRY_RUN=true

# encode H.264 on the iGPU (VAAPI) instead of CPU x264 — strongly recommended
# when streaming music (frees CPU for the screencast capture). Needs renderD128.
HW_ENCODE=true

# delay output audio to line up with the eq bars (ms). The video pipeline lags
# the audio; tune this by eye until the bars hit the beat (~2000 on this rig).
AUDIO_DELAY_MS=2000
